<Window x:Class="KinectCaptureApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kinect Capture App - All Streams"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <!-- Main 2x2 layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ================= COLOR ================= -->
        <Border Grid.Row="0" Grid.Column="0" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Color (RGB)"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="Both">
                    <Image Name="ColorImage"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Viewbox>
            </Grid>
        </Border>

        <!-- ================= DEPTH ================= -->
        <Border Grid.Row="0" Grid.Column="1" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Depth"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <Viewbox Grid.Row="1" Stretch="Uniform">
                    <Image Name="DepthImage" Stretch="Uniform"/>
                </Viewbox>
            </Grid>
        </Border>

        <!-- ================= INFRARED ================= -->
        <Border Grid.Row="1" Grid.Column="0" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Infrared (IR)"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <Viewbox Grid.Row="1" Stretch="Uniform">
                    <Image Name="InfraredImage" Stretch="Uniform"/>
                </Viewbox>
            </Grid>
        </Border>

        <!-- ================= SKELETON ================= -->
        <Border Grid.Row="1" Grid.Column="1" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Skeleton Tracking"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <!-- Fixed logical size to match Kinect depth resolution -->
                <Viewbox Grid.Row="1" Stretch="Uniform">
                    <Canvas Name="SkeletonCanvas"
                            Width="512"
                            Height="424"
                            Background="Black"
                            IsHitTestVisible="False"/>
                </Viewbox>
            </Grid>
        </Border>
    </Grid>
</Window>