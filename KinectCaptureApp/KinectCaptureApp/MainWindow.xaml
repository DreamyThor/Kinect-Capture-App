<Window x:Class="KinectCaptureApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kinect Capture App - All Streams"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <!-- Main layout: 2 stream rows + recording bar -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ================= COLOR ================= -->
        <Border Grid.Row="0" Grid.Column="0" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Color (RGB)"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="Both">
                    <Image Name="ColorImage"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Viewbox>
            </Grid>
        </Border>

        <!-- ================= DEPTH ================= -->
        <Border Grid.Row="0" Grid.Column="1" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Depth"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <Viewbox Grid.Row="1" Stretch="Uniform">
                    <Image Name="DepthImage" Stretch="Uniform"/>
                </Viewbox>
            </Grid>
        </Border>

        <!-- ================= INFRARED ================= -->
        <Border Grid.Row="1" Grid.Column="0" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Infrared (IR)"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <Viewbox Grid.Row="1" Stretch="Uniform">
                    <Image Name="InfraredImage" Stretch="Uniform"/>
                </Viewbox>
            </Grid>
        </Border>

        <!-- ================= SKELETON ================= -->
        <Border Grid.Row="1" Grid.Column="1" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Skeleton Tracking"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <Viewbox Grid.Row="1" Stretch="Uniform">
                    <Canvas Name="SkeletonCanvas"
                            Width="512"
                            Height="424"
                            Background="Black"
                            IsHitTestVisible="False"/>
                </Viewbox>
            </Grid>
        </Border>

        <!-- ================= RECORDING BAR ================= -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Margin="5,5,5,5"
                BorderBrush="Gray" BorderThickness="1"
                Background="#1a1a1a"
                CornerRadius="4">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,8">

                <Button Name="RecordButton"
                        Content="⏺  Start Recording"
                        Width="160"
                        Height="34"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Background="#CC2222"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="RecordButton_Click"/>

                <TextBlock Name="RecordingStatusLabel"
                           Text="Not recording"
                           Foreground="#AAAAAA"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>
